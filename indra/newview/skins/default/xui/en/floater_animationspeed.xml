<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<floater
    positioning="centered"
    legacy_header_height="18"
    can_resize="false"
    can_dock="true"
    can_close="true"
    height="100"
    width="260"
    layout="topleft"
    name="animationspeed"
    save_rect="true"
    save_visibility="true"
    single_instance="true"
    save_dock_state="true"
    title="Animation Speed">
<panel
    name="animationspeed"
    left="0"
    top="16"
    width="260"
    height="80"
    follows="all"
    layout="topleft">
    <text
        type="string"
        length="1"
        follows="left|top"
        height="10"
        layout="topleft"
        left="5"
        name="SpeedLabel"
        top_pad="10"
        width="90">
        Speed:
    </text>
    <slider
        text_width="40"
        can_edit_text="true"
        decimal_digits="1"
        follows="left|right|top"
        height="16"
        increment="0.1"
        initial_value="1.0"
        layout="topleft"
        left_pad="5"
        max_val="10.0"
        min_val="0.1"
        name="speed_slider"
        top_delta="-2"
        right="-7" />
    <button
        enabled="true"
        name="reset_btn"
        label="Reset"
        tool_tip="Reset animation speed to 1.0x"
        top_pad="10"
        left="5"
        height="20"
        width="90"
        follows="left|top" />
</panel>
</floater>
