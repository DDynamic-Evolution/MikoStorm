<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<floater
 height="140"
 width="400"
 layout="topleft"
 positioning="centered"
 legacy_header_height="18"
 can_resize="false"
 name="floater_fs_im_sound"
 title="Set IM Sound...">
	<text
	 type="string"
	 follows="left|top"
	 height="18"
	 layout="topleft"
	 left="8"
	 name="label_name"
	 top="20"
	 width="385">
Set custom IM sound for:
	</text>
	<text
	 type="string"
	 follows="left|top"
	 height="18"
	 layout="topleft"
	 left="8"
	 name="label_avatar_name"
	 word_wrap="true"
	 top_pad="2"
	 width="385">
	</text>
	<text
	 type="string"
	 follows="left|top"
	 height="14"
	 layout="topleft"
	 left="8"
	 name="label_uuid"
	 top_pad="6"
	 width="385">
Sound UUID:
	</text>
	<line_editor
	 follows="left|top"
	 height="23"
	 layout="topleft"
	 left="8"
	 top_pad="2"
	 name="sound_uuid_editor"
	 width="385"
	 max_length="36"
	 allow_tab="false"
	 commit_on_focus_lost="true"/>
	<button
	 left="8"
	 top_pad="4"
	 follows="top|right"
	 layout="topleft"
	 height="22"
	 label="Preview"
	 name="preview_btn"
	 width="80" />
	<button
	 left_pad="4"
	 top_delta="0"
	 follows="top|right"
	 layout="topleft"
	 height="22"
	 label="Clear"
	 name="clear_btn"
	 width="80" />
	<button
	 left_pad="8"
	 top_delta="0"
	 follows="top|right"
	 layout="topleft"
	 height="22"
	 label="OK"
	 name="ok_btn"
	 width="80" />
	<button
	 left_pad="4"
	 top_delta="0"
	 follows="top|right"
	 layout="topleft"
	 height="22"
	 label="Cancel"
	 name="cancel_btn"
	 width="80" />
</floater>
